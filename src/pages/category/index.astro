---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TagPill from '../../components/TagPill.astro';

const posts = await getCollection('posts', ({ data }) => !data.draft);
const categoryCounts = new Map<string, number>();
for (const post of posts) {
  for (const category of post.data.categories) {
    categoryCounts.set(category, (categoryCounts.get(category) ?? 0) + 1);
  }
}
const categories = [...categoryCounts.entries()].sort((a, b) => a[0].localeCompare(b[0]));
---

<BaseLayout title="Categories">
  <h1 class="text-2xl font-bold text-slate-900">Categories</h1>
  <div class="mt-6 flex flex-wrap gap-3">
    {
      categories.map(([category, count]) => (
        <TagPill href={`/category/${category}/`} label={`${category} (${count})`} />
      ))
    }
  </div>
</BaseLayout>
