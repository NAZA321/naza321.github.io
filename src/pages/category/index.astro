---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TaxonomyCard from '../../components/TaxonomyCard.astro';

const posts = await getCollection('posts', ({ data }) => !data.draft);
const categoryCounts = new Map<string, number>();
for (const post of posts) {
  for (const category of post.data.categories) {
    categoryCounts.set(category, (categoryCounts.get(category) ?? 0) + 1);
  }
}
const categories = [...categoryCounts.entries()].sort((a, b) => a[0].localeCompare(b[0]));
---

<BaseLayout title="Categories" wide>
  <h1 class="mb-2 text-2xl font-bold tracking-tight text-slate-900">Categories</h1>
  <p class="mb-8 text-slate-500">{categories.length} 個のカテゴリー</p>
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {
      categories.map(([category, count]) => (
        <TaxonomyCard href={`/category/${category}/`} name={category} count={count} />
      ))
    }
  </div>
</BaseLayout>
