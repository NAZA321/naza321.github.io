---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import NewsList from '../components/NewsList.astro';

// TOPページのヒーロー画像（オリジナルのSVG、回路・ネットワークテーマ）。
// 差し替える場合は public/images/top/ に画像を置き、このパスを変更する。
const heroImage = '/images/top/hero.svg';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);

const newsEntries = await getCollection('news');
const newsItems = newsEntries[0]?.data.items ?? [];
---

<BaseLayout title="nazaのブログ" wide>
  <div class="relative mb-12 aspect-[16/9] overflow-hidden rounded-2xl sm:aspect-[3/1]">
    <img src={heroImage} alt="naza" class="h-full w-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent" />
    <div class="absolute inset-0 flex flex-col items-start justify-end p-6 md:p-10">
      <h1 class="text-3xl font-bold tracking-tight text-white md:text-4xl">NAZA</h1>
      <p class="mt-2 text-white/80">日々の記録や学びを書いていくブログです。</p>
    </div>
  </div>

  {newsItems.length > 0 && <NewsList items={newsItems} />}

  <h2 class="mb-6 text-xl font-bold tracking-tight text-slate-900">最近の記事</h2>
  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {posts.map((entry) => <PostCard entry={entry} />)}
  </div>
  <a href="/posts/" class="mt-8 inline-block font-medium text-indigo-600 hover:text-indigo-700">
    すべての記事を見る →
  </a>
</BaseLayout>
