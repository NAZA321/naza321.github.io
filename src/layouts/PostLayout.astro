---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import TagPill from '../components/TagPill.astro';

interface Props {
  entry: CollectionEntry<'posts'>;
}

const { entry } = Astro.props;
const { title, date, description, tags, categories, heroImage } = entry.data;
const formattedDate = date.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <article>
    <header class="mb-8">
      <h1 class="text-3xl font-bold text-slate-900">{title}</h1>
      <p class="mt-2 text-sm text-slate-400">{formattedDate}</p>
      <div class="mt-3 flex flex-wrap gap-2">
        {categories.map((category) => (
          <TagPill href={`/category/${category}/`} label={category} />
        ))}
        {tags.map((tag) => (
          <TagPill href={`/tags/${tag}/`} label={`#${tag}`} />
        ))}
      </div>
      {heroImage && <img src={heroImage} alt={title} class="mt-6 w-full rounded-lg" />}
    </header>
    <div class="prose prose-slate max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
