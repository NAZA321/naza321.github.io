---
import type { CollectionEntry } from 'astro:content';
import TagPill from './TagPill.astro';

interface Props {
  entry: CollectionEntry<'posts'>;
}

const { entry } = Astro.props;
const { title, date, description, tags } = entry.data;
const formattedDate = date.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="border-b border-slate-100 py-6">
  <a href={`/posts/${entry.id}/`} class="text-xl font-semibold text-slate-900 hover:underline">
    {title}
  </a>
  <p class="mt-1 text-sm text-slate-400">{formattedDate}</p>
  {description && <p class="mt-2 text-slate-600">{description}</p>}
  {
    tags.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <TagPill href={`/tags/${tag}/`} label={tag} />
        ))}
      </div>
    )
  }
</article>
