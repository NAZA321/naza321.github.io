---
import type { CollectionEntry } from 'astro:content';
import TagPill from './TagPill.astro';
import PostCover from './PostCover.astro';

interface Props {
  entry: CollectionEntry<'posts'>;
}

const { entry } = Astro.props;
const { title, date, description, tags, heroImage } = entry.data;
const formattedDate = date.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const href = `/posts/${entry.id}/`;
---

<article class="group overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm transition-shadow hover:shadow-md">
  <a href={href} class="block aspect-[16/9] overflow-hidden">
    <PostCover title={title} image={heroImage} titleClass="text-base line-clamp-3 px-2" />
  </a>
  <div class="p-5">
    <a href={href} class="font-bold text-slate-900 group-hover:text-indigo-600">
      {title}
    </a>
    <p class="mt-1 text-sm text-slate-400">{formattedDate}</p>
    {description && <p class="mt-2 text-sm text-slate-600">{description}</p>}
    {
      tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-2">
          {tags.map((tag) => (
            <TagPill href={`/tags/${tag}/`} label={tag} />
          ))}
        </div>
      )
    }
  </div>
</article>
