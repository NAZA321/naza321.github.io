---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import PostCard from './PostCard.astro';

interface Props {
  current: CollectionEntry<'posts'>;
  limit?: number;
}

const { current, limit = 3 } = Astro.props;

// タグを主・カテゴリーを補助として関連度をスコア化する。
const TAG_WEIGHT = 2;
const CATEGORY_WEIGHT = 1;

const currentTags = new Set(current.data.tags);
const currentCategories = new Set(current.data.categories);

const all = await getCollection('posts', ({ data }) => !data.draft);

const related = all
  .filter((post) => post.id !== current.id)
  .map((post) => {
    const sharedTags = post.data.tags.filter((t) => currentTags.has(t)).length;
    const sharedCategories = post.data.categories.filter((c) => currentCategories.has(c)).length;
    return { post, score: sharedTags * TAG_WEIGHT + sharedCategories * CATEGORY_WEIGHT };
  })
  .filter(({ score }) => score > 0)
  .sort(
    (a, b) => b.score - a.score || b.post.data.date.valueOf() - a.post.data.date.valueOf(),
  )
  .slice(0, limit)
  .map(({ post }) => post);
---

{
  related.length > 0 && (
    <section class="mt-16 border-t border-slate-200 pt-10">
      <h2 class="mb-6 text-xl font-bold tracking-tight text-slate-900">おすすめの記事</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {related.map((entry) => (
          <PostCard entry={entry} />
        ))}
      </div>
    </section>
  )
}
