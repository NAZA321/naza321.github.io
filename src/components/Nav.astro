---
const links = [
  { href: '/posts/', label: 'Posts' },
  { href: '/tags/', label: 'Tags' },
  { href: '/category/', label: 'Categories' },
  { href: '/about/', label: 'About' },
];

const isActive = (href: string) => Astro.url.pathname === href;
---

<header class="sticky top-0 z-10 border-b border-slate-200 bg-white/80 backdrop-blur">
  <nav class="mx-auto flex max-w-5xl items-center justify-between px-4 py-4">
    <a href="/" class="text-lg font-bold tracking-tight text-slate-900">HOME PAGE</a>
    <div class="flex gap-6">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={[
              'text-sm font-medium text-slate-500 hover:text-indigo-600',
              { 'text-indigo-600': isActive(link.href) },
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </nav>
</header>
