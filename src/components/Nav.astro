---
const links = [
  { href: '/', label: 'Home' },
  { href: '/posts/', label: 'Posts' },
  { href: '/tags/', label: 'Tags' },
  { href: '/category/', label: 'Categories' },
  { href: '/about/', label: 'About' },
];
---

<header class="border-b border-slate-200">
  <nav class="mx-auto flex max-w-3xl items-center gap-6 px-4 py-4">
    {
      links.map((link) => (
        <a
          href={link.href}
          class="text-slate-600 hover:text-slate-900 aria-[current]:font-semibold aria-[current]:text-slate-900"
          aria-current={Astro.url.pathname === link.href ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))
    }
  </nav>
</header>
